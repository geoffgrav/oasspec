openapi: "3.0.1"
info:
  title: "OAS Spec Validation"
  description: "OpenAPI Specification for the Gravitee Echo API - used to demonstrate OAS validation and CI/CD promotion workflows"
  version: "1.0.0"
servers:
  - url: "https://api.gravitee.io"
    description: "Gravitee Public Echo API"
paths:
  /:
    get:
      summary: "Echo request details"
      description: "Returns all headers, query parameters and body size from the incoming request. Useful for validating gateway behaviour."
      operationId: "echoGet"
      parameters:
        - name: "example_param"
          in: "query"
          required: false
          description: "Any query parameter - will be reflected back in the response"
          schema:
            type: "string"
            example: "hello"
      responses:
        "200":
          description: "Echo response containing all request details"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/EchoResponse"
    post:
      summary: "Echo request with body"
      description: "Returns headers, query params and body size for a POST request"
      operationId: "echoPost"
      requestBody:
        description: "Any payload - will be reflected back"
        content:
          application/json:
            schema:
              type: "object"
      responses:
        "200":
          description: "Echo response containing all request details"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/EchoResponse"
components:
  schemas:
    EchoResponse:
      type: "object"
      properties:
        headers:
          type: "object"
          description: "All request headers received by the gateway"
          additionalProperties:
            type: "string"
          example:
            Host: "api.gravitee.io"
            X-Gravitee-Request-Id: "8fe6a2e0-9967-481c-a6a2-e09967c81ced"
            X-Gravitee-Transaction-Id: "8fe6a2e0-9967-481c-a6a2-e09967c81ced"
            User-Agent: "Mozilla/5.0"
        query_params:
          type: "object"
          description: "All query parameters passed in the request"
          additionalProperties:
            type: "string"
        bodySize:
          type: "integer"
          description: "Size of the request body in bytes"
          example: 0
